---
---

<section id="precios" style="background:var(--bg-2)">
  <div class="wrap">
    <div class="sec-head center">
      <div>
        <span class="kicker kicker-dot">Precios</span>
        <h2>Simple y transparente.</h2>
        <p class="lead">No pagamos por servidores de IA — tu teléfono hace el trabajo. Por eso es gratis <em>de verdad</em>.</p>
      </div>
    </div>

    <div class="price-toggle-wrap">
      <div class="price-toggle" role="tablist">
        <button id="tgMonth">Mensual</button>
        <button id="tgYear" class="active">Anual <span class="save">-17%</span></button>
      </div>
    </div>

    <div class="pricing-grid">
      <article class="price-card">
        <span class="price-name">Gratis</span>
        <div class="price-amount">US$0</div>
        <div class="price-period">para siempre</div>
        <div class="price-desc">Ideal si cuidas un grupo pequeño-mediano.</div>
        <ul>
          <li class="star">Análisis ilimitados</li>
          <li>Ranking de participación</li>
          <li>Semáforo verde/amarillo/rojo</li>
          <li>Heatmap de actividad 7×24</li>
          <li>Estadísticas de mensajes</li>
          <li>Menciones frecuentes</li>
          <li>Detección de eventos</li>
        </ul>
        <a class="btn btn-ghost btn-lg" href="#descargar" style="justify-content:center;border:1px solid var(--line)">Descargar gratis</a>
      </article>

      <article class="price-card featured">
        <span class="price-badge">Recomendado</span>
        <span class="price-name">Pro</span>
        <div class="price-amount">US$<span id="priceAmt">80</span><sup id="priceCents">/año</sup></div>
        <div class="price-period" id="priceSub">Equivale a US$6.67/mes · 2 meses gratis</div>
        <div class="price-desc">Para admins que exigen participación.</div>
        <ul>
          <li>Todo lo de Gratis</li>
          <li class="star">Resúmenes con IA</li>
          <li class="star">Pregunta a la IA (on-device)</li>
          <li>Panel de salud del grupo</li>
          <li>Alertas de silencios</li>
          <li>Análisis de sentimiento</li>
          <li>Lista de inactivos con evidencia</li>
          <li>Tiempos de respuesta</li>
          <li>FAQ auto-generadas</li>
          <li>Notas y etiquetas por miembro</li>
        </ul>
        <a class="btn btn-accent btn-lg" href="#descargar" style="justify-content:center">Probar Pro gratis →</a>
      </article>

      <article class="price-card">
        <span class="price-name">Teams</span>
        <div class="price-amount">US$15<sup>/mes</sup></div>
        <div class="price-period">por administrador</div>
        <div class="price-desc">Para comunidades con múltiples grupos.</div>
        <ul>
          <li>Todo lo de Pro</li>
          <li class="star">Perfil multi-grupo por miembro</li>
          <li class="star">Análisis comparativo entre grupos</li>
          <li>Acceso a API</li>
          <li>Soporte prioritario</li>
        </ul>
        <a class="btn btn-ghost btn-lg" href="/contacto" style="justify-content:center;border:1px solid var(--line)">Contactar ventas</a>
      </article>
    </div>
    <p class="price-fineprint">Precios en USD · Detectamos tu moneda local al comprar</p>
  </div>
</section>

<script>
  const tgMonth = document.getElementById('tgMonth');
  const tgYear = document.getElementById('tgYear');
  const priceAmt = document.getElementById('priceAmt');
  const priceCents = document.getElementById('priceCents');
  const priceSub = document.getElementById('priceSub');
  tgMonth.addEventListener('click', () => {
    tgMonth.classList.add('active'); tgYear.classList.remove('active');
    priceAmt.textContent = '8'; priceCents.textContent = '/mes';
    priceSub.textContent = 'Facturación mensual · cancela cuando quieras';
  });
  tgYear.addEventListener('click', () => {
    tgYear.classList.add('active'); tgMonth.classList.remove('active');
    priceAmt.textContent = '80'; priceCents.textContent = '/año';
    priceSub.textContent = 'Equivale a US$6.67/mes · 2 meses gratis';
  });
</script>
