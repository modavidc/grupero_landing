---
const plans = [
    {
        name: "Gratis",
        priceMonthly: "$0",
        priceAnnual: "$0",
        periodMonthly: "para siempre",
        periodAnnual: "para siempre",
        note: "No pagamos servidores de IA — tu teléfono hace el trabajo. Por eso es gratis de verdad.",
        features: [
            "Análisis ilimitados",
            "Ranking de participación",
            "Semáforo de participación",
            "Heatmap de actividad 7x24",
            "Estadísticas de mensajes",
            "Gráficos de actividad",
            "Menciones frecuentes",
            "Iniciadores de conversación",
            "Detección de eventos"
        ],
        cta: "Descargar gratis",
        ctaClass: "btn-ghost",
        href: "#descargar",
        featured: false
    },
    {
        name: "Pro",
        priceMonthly: "US$8",
        priceAnnual: "US$6.67",
        suffixMonthly: "/mes",
        suffixAnnual: "/mes",
        periodMonthly: "facturado mensualmente",
        periodAnnual: "US$80/año — ahorras 2 meses",
        features: [
            "Todo de Gratis",
            { text: "Resúmenes con IA", star: true },
            { text: "Pregunta a la IA", star: true },
            "Panel de salud del grupo",
            "Alertas de silencios",
            "Análisis de sentimiento",
            "Lista de inactivos con evidencia",
            "Tiempos de respuesta",
            "Mensajes eliminados",
            "FAQ auto-generadas",
            "Notas y etiquetas por miembro"
        ],
        cta: "Descargar y probar Pro",
        ctaClass: "btn-primary",
        href: "#descargar",
        featured: true
    },
    {
        name: "Teams",
        priceMonthly: "US$15",
        priceAnnual: "US$12.50",
        suffixMonthly: "/mes",
        suffixAnnual: "/mes",
        periodMonthly: "por administrador",
        periodAnnual: "US$150/año por administrador",
        features: [
            "Todo de Pro",
            "Perfil multi-grupo por miembro",
            "Análisis comparativo entre grupos",
            "Acceso a API",
            "Soporte prioritario"
        ],
        cta: "Contactar ventas",
        ctaClass: "btn-ghost",
        href: "/contacto",
        featured: false
    }
];
---

<section id="precios" class="pricing">
    <div class="container">
        <h2 class="section-title">Simple y transparente</h2>
        <p class="section-subtitle">Empieza gratis, escala cuando lo necesites</p>

        <div class="billing-toggle">
            <span class="toggle-label" id="label-monthly">Mensual</span>
            <button class="toggle-switch" id="billing-toggle" aria-pressed="true" aria-label="Cambiar a facturación mensual o anual">
                <span class="toggle-thumb"></span>
            </button>
            <span class="toggle-label" id="label-annual">
                Anual
                <span class="save-badge">Ahorra 17%</span>
            </span>
        </div>

        <div class="pricing-grid">
            {plans.map(plan => (
                <div class:list={["pricing-card", { featured: plan.featured }]}>
                    {plan.featured && <div class="pricing-badge">Recomendado</div>}
                    <h3>{plan.name}</h3>

                    <div class="price">
                        <span class="price-monthly">{plan.priceMonthly}{plan.suffixMonthly && <span class="price-suffix">{plan.suffixMonthly}</span>}</span>
                        <span class="price-annual">{plan.priceAnnual}{plan.suffixAnnual && <span class="price-suffix">{plan.suffixAnnual}</span>}</span>
                    </div>
                    <p class="price-period">
                        <span class="period-monthly">{plan.periodMonthly}</span>
                        <span class="period-annual">{plan.periodAnnual}</span>
                    </p>

                    {plan.note && <p class="plan-note">{plan.note}</p>}
                    <ul class="pricing-features">
                        {plan.features.map(f =>
                            typeof f === 'string'
                                ? <li>{f}</li>
                                : <li class="feature-star">{f.text} <span class="star-pill">⭐ destacado</span></li>
                        )}
                    </ul>
                    <a href={plan.href} class:list={["btn", "btn-full", plan.ctaClass]}>{plan.cta}</a>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .pricing { padding: 100px 0; background: var(--color-bg); }

    /* Toggle */
    .billing-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        margin: 32px 0 48px;
    }

    .toggle-label {
        font-size: 0.95rem;
        font-weight: 500;
        color: var(--color-text-muted);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .toggle-label.active {
        color: var(--color-text);
        font-weight: 600;
    }

    .save-badge {
        background: #dcfce7;
        color: #15803d;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 3px 8px;
        border-radius: 9999px;
    }

    .toggle-switch {
        position: relative;
        width: 48px;
        height: 26px;
        background: var(--color-primary);
        border: none;
        border-radius: 9999px;
        cursor: pointer;
        transition: background 0.2s;
        padding: 0;
    }

    .toggle-thumb {
        position: absolute;
        top: 3px;
        left: 3px;
        width: 20px;
        height: 20px;
        background: white;
        border-radius: 50%;
        transition: transform 0.2s;
        display: block;
    }

    .toggle-switch[aria-pressed="false"] .toggle-thumb {
        transform: translateX(22px);
    }

    /* Price visibility */
    .price-annual,
    .period-annual { display: none; }

    .pricing[data-billing="annual"] .price-monthly,
    .pricing[data-billing="annual"] .period-monthly { display: none; }

    .pricing[data-billing="annual"] .price-annual,
    .pricing[data-billing="annual"] .period-annual { display: inline; }

    /* Cards */
    .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; max-width: 1000px; margin: 0 auto; }
    .pricing-card { position: relative; background: var(--color-white); padding: 40px 32px; border-radius: var(--radius-lg); border: 2px solid var(--color-border); text-align: center; }
    .pricing-card.featured { border-color: var(--color-primary); box-shadow: var(--shadow-xl); transform: scale(1.05); }
    .pricing-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%); color: white; font-size: 0.75rem; font-weight: 600; padding: 6px 16px; border-radius: var(--radius-full); white-space: nowrap; }
    .pricing-card h3 { font-size: 1.25rem; font-weight: 700; margin-bottom: 16px; }
    .price { font-size: 3rem; font-weight: 800; color: var(--color-primary-dark); }
    .price-suffix { font-size: 1rem; font-weight: 500; color: var(--color-text-muted); }
    .price-period { font-size: 0.875rem; color: var(--color-text-muted); margin-bottom: 24px; min-height: 1.4em; }
    .pricing-features { text-align: left; margin-bottom: 32px; }
    .pricing-features li { padding: 8px 0; border-bottom: 1px solid var(--color-border); font-size: 0.95rem; }
    .pricing-features li:last-child { border-bottom: none; }
    .pricing-features li::before { content: '✓'; color: var(--color-primary); font-weight: 700; margin-right: 8px; }
    .feature-star { font-weight: 600; }
    .star-pill { font-size: 0.7rem; background: #fef9c3; color: #854d0e; padding: 2px 7px; border-radius: 9999px; font-weight: 600; margin-left: 6px; vertical-align: middle; }
    .plan-note { font-size: 0.8rem; color: var(--color-text-muted); font-style: italic; margin-bottom: 20px; line-height: 1.5; text-align: left; }

    @media (max-width: 1024px) {
        .pricing-grid { grid-template-columns: 1fr; max-width: 400px; }
        .pricing-card.featured { transform: none; }
    }
</style>

<script>
    const section = document.getElementById('precios') as HTMLElement;
    const toggle = document.getElementById('billing-toggle') as HTMLButtonElement;
    const labelMonthly = document.getElementById('label-monthly');
    const labelAnnual = document.getElementById('label-annual');

    let isAnnual = true;

    const update = () => {
        section.dataset.billing = isAnnual ? 'annual' : 'monthly';
        toggle.setAttribute('aria-pressed', isAnnual ? 'true' : 'false');
        labelMonthly?.classList.toggle('active', !isAnnual);
        labelAnnual?.classList.toggle('active', isAnnual);
    };

    toggle.addEventListener('click', () => {
        isAnnual = !isAnnual;
        update();
    });

    update();
</script>
