<section class="mini-cta">
    <div class="container">
        <div class="mini-cta-content">
            <div class="mini-cta-text">
                <h3>Pruébalo gratis</h3>
                <p>Analiza tu primer grupo en menos de 2 minutos</p>
            </div>
            <div class="mini-cta-buttons">
                <a href="#descargar" class="btn-mini-cta">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/>
                    </svg>
                    Descargar ahora
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    .mini-cta {
        padding: 48px 0;
        background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
        border-top: 1px solid #bbf7d0;
        border-bottom: 1px solid #bbf7d0;
    }

    .mini-cta-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 32px;
        flex-wrap: wrap;
    }

    .mini-cta-text h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #166534;
        margin-bottom: 4px;
    }

    .mini-cta-text p {
        color: #15803d;
        font-size: 1rem;
    }

    .btn-mini-cta {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
        color: white;
        padding: 14px 28px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.2s ease;
        box-shadow: 0 4px 14px rgba(34, 197, 94, 0.4);
    }

    .btn-mini-cta:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(34, 197, 94, 0.5);
    }

    .btn-mini-cta svg {
        flex-shrink: 0;
    }

    @media (max-width: 640px) {
        .mini-cta-content {
            flex-direction: column;
            text-align: center;
        }

        .mini-cta-text h3 {
            font-size: 1.25rem;
        }
    }
</style>
