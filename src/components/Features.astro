---

---

<section id="features" class="features">
    <div class="container">
        <div class="features-header">
            <span class="features-badge">Funcionalidades</span>
            <h2 class="section-title">El que más escribe no es el que más aporta.</h2>
            <p class="section-subtitle">Grupero mide lo que importa, no lo que se ve</p>
        </div>

        <div class="features-list">
            <!-- Feature 1: Semáforo -->
            <div class="feature-row">
                <div class="feature-visual">
                    <div class="phone">
                        <div class="phone-notch"></div>
                        <div class="phone-screen">
                            <div class="screen-header">
                                <span>← Papás Colegio Montessori</span>
                            </div>
                            <div class="screen-body">
                                <div class="health-card">
                                    <div class="health-top">
                                        <span class="health-emoji">💚</span>
                                        <div class="health-text">
                                            <small>Salud del grupo</small>
                                            <strong>Excelente</strong>
                                        </div>
                                        <div class="health-score">87</div>
                                    </div>
                                    <div class="health-row">
                                        <div class="health-stat"><span>👥</span><b>45</b>Activos</div>
                                        <div class="health-stat"><span>⚠️</span><b>8</b>Riesgo</div>
                                        <div class="health-stat"><span>💤</span><b>3</b>Inactivos</div>
                                    </div>
                                </div>
                                <div class="sem-card">
                                    <div class="sem-title">Estado del grupo</div>
                                    <div class="sem-bars">
                                        <div class="bar green"><div class="dot"></div><span>45</span><small>Activos</small></div>
                                        <div class="bar yellow"><div class="dot"></div><span>8</span><small>Riesgo</small></div>
                                        <div class="bar red"><div class="dot"></div><span>3</span><small>Inactivos</small></div>
                                    </div>
                                    <div class="sem-progress">
                                        <div class="fill-green"></div>
                                        <div class="fill-yellow"></div>
                                        <div class="fill-red"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="feature-text">
                    <h3>Panel de salud + Semáforo</h3>
                    <p>De un vistazo: verde = activos, amarillo = en riesgo, rojo = inactivos. El score de 0-100 te dice qué tan sano está tu grupo. Simple y claro.</p>
                </div>
            </div>

            <!-- Feature 2: Ranking -->
            <div class="feature-row reverse">
                <div class="feature-visual">
                    <div class="phone">
                        <div class="phone-notch"></div>
                        <div class="phone-screen">
                            <div class="screen-header">
                                <span>← Running Club CDMX</span>
                            </div>
                            <div class="screen-body">
                                <div class="rank-card">
                                    <div class="rank-title">🏆 Ranking de participación</div>
                                    <div class="rank-list">
                                        <div class="rank-row"><span class="medal">🥇</span><div class="avatar a1">LV</div><div class="rank-info"><strong>Laura Vega</strong><div class="rank-bar"><div class="fill" style="width:100%"></div></div></div><div class="rank-num"><b>847</b><small>18%</small></div></div>
                                        <div class="rank-row"><span class="medal">🥈</span><div class="avatar a2">AK</div><div class="rank-info"><strong>Andrés Kim</strong><div class="rank-bar"><div class="fill" style="width:78%"></div></div></div><div class="rank-num"><b>661</b><small>14%</small></div></div>
                                        <div class="rank-row"><span class="medal">🥉</span><div class="avatar a3">SR</div><div class="rank-info"><strong>Sofía Reyes</strong><div class="rank-bar"><div class="fill" style="width:65%"></div></div></div><div class="rank-num"><b>551</b><small>12%</small></div></div>
                                        <div class="rank-row"><span class="pos">#4</span><div class="avatar a4">MT</div><div class="rank-info"><strong>Miguel Torres</strong><div class="rank-bar"><div class="fill" style="width:52%"></div></div></div><div class="rank-num"><b>440</b><small>9%</small></div></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="feature-text">
                    <h3>Ranking de participación real</h3>
                    <p>No solo cuenta mensajes. Ve quién realmente aporta: responde eventos, organiza, participa. El verdadero top del grupo con medallas y porcentajes.</p>
                </div>
            </div>

            <!-- Feature 3: Alertas -->
            <div class="feature-row">
                <div class="feature-visual">
                    <div class="phone">
                        <div class="phone-notch"></div>
                        <div class="phone-screen">
                            <div class="screen-header">
                                <span>← Cena Mensual Amigos</span>
                            </div>
                            <div class="screen-body">
                                <div class="alert-card">
                                    <div class="alert-title">⚠️ Alertas de silencio</div>
                                    <div class="alert-sub">2 miembros importantes</div>
                                    <div class="alert-list">
                                        <div class="alert-row">
                                            <div class="alert-badge">#3</div>
                                            <div class="alert-info"><strong>Roberto Castro</strong><small>Sin actividad en 14 días</small></div>
                                            <div class="alert-decay">📉 75%</div>
                                        </div>
                                        <div class="alert-row">
                                            <div class="alert-badge">#7</div>
                                            <div class="alert-info"><strong>Diana Flores</strong><small>Sin actividad en 9 días</small></div>
                                            <div class="alert-decay">📉 50%</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="feature-text">
                    <h3>Alertas de silencios críticos</h3>
                    <p>Cuando alguien importante deja de participar, te avisamos. Detecta patrones de abandono y actúa antes de que se vayan del grupo.</p>
                </div>
            </div>

            <!-- Feature 4: Heatmap -->
            <div class="feature-row reverse">
                <div class="feature-visual">
                    <div class="phone">
                        <div class="phone-notch"></div>
                        <div class="phone-screen">
                            <div class="screen-header">
                                <span>← Fútbol Domingos</span>
                            </div>
                            <div class="screen-body">
                                <div class="heat-card">
                                    <div class="heat-title">📊 Actividad semanal</div>
                                    <div class="heatmap">
                                        <div class="heat-row"><span>Lun</span><div class="cells"><i class="c0"></i><i class="c0"></i><i class="c1"></i><i class="c2"></i><i class="c3"></i><i class="c2"></i><i class="c3"></i><i class="c4"></i><i class="c2"></i><i class="c1"></i><i class="c0"></i><i class="c0"></i></div></div>
                                        <div class="heat-row"><span>Mar</span><div class="cells"><i class="c0"></i><i class="c0"></i><i class="c1"></i><i class="c1"></i><i class="c2"></i><i class="c2"></i><i class="c2"></i><i class="c3"></i><i class="c2"></i><i class="c1"></i><i class="c0"></i><i class="c0"></i></div></div>
                                        <div class="heat-row"><span>Mié</span><div class="cells"><i class="c0"></i><i class="c0"></i><i class="c1"></i><i class="c2"></i><i class="c2"></i><i class="c1"></i><i class="c2"></i><i class="c3"></i><i class="c2"></i><i class="c1"></i><i class="c0"></i><i class="c0"></i></div></div>
                                        <div class="heat-row"><span>Jue</span><div class="cells"><i class="c0"></i><i class="c0"></i><i class="c1"></i><i class="c2"></i><i class="c2"></i><i class="c2"></i><i class="c3"></i><i class="c3"></i><i class="c2"></i><i class="c1"></i><i class="c0"></i><i class="c0"></i></div></div>
                                        <div class="heat-row"><span>Vie</span><div class="cells"><i class="c0"></i><i class="c0"></i><i class="c1"></i><i class="c1"></i><i class="c2"></i><i class="c3"></i><i class="c4"></i><i class="c4"></i><i class="c3"></i><i class="c2"></i><i class="c1"></i><i class="c0"></i></div></div>
                                        <div class="heat-row"><span>Sáb</span><div class="cells"><i class="c0"></i><i class="c0"></i><i class="c1"></i><i class="c2"></i><i class="c3"></i><i class="c4"></i><i class="c4"></i><i class="c4"></i><i class="c3"></i><i class="c2"></i><i class="c1"></i><i class="c0"></i></div></div>
                                        <div class="heat-row"><span>Dom</span><div class="cells"><i class="c0"></i><i class="c0"></i><i class="c2"></i><i class="c3"></i><i class="c4"></i><i class="c4"></i><i class="c4"></i><i class="c4"></i><i class="c3"></i><i class="c2"></i><i class="c1"></i><i class="c0"></i></div></div>
                                    </div>
                                    <div class="heat-legend"><span>Menos</span><i class="c0"></i><i class="c1"></i><i class="c2"></i><i class="c3"></i><i class="c4"></i><span>Más</span></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="feature-text">
                    <h3>Heatmap de actividad</h3>
                    <p>Visualiza cuándo tu grupo está más activo. Identifica los mejores horarios para publicar eventos o mensajes importantes. Domingos a las 6pm = fuego.</p>
                </div>
            </div>

            <!-- Feature 5: Eventos -->
            <div class="feature-row">
                <div class="feature-visual">
                    <div class="phone">
                        <div class="phone-notch"></div>
                        <div class="phone-screen">
                            <div class="screen-header">
                                <span>← Equipo Producto Acme</span>
                            </div>
                            <div class="screen-body">
                                <div class="events-card">
                                    <div class="events-title">📅 Eventos detectados</div>
                                    <div class="events-list">
                                        <div class="event-row next">
                                            <div class="ev-date"><b>18</b><small>ABR</small></div>
                                            <div class="ev-info"><strong>Demo trimestral Q2</strong><div class="ev-resp"><span class="yes">✓14</span><span class="no">✗3</span><span class="maybe">?5</span></div></div>
                                            <div class="ev-badge">Próximo</div>
                                        </div>
                                        <div class="event-row">
                                            <div class="ev-date"><b>10</b><small>ABR</small></div>
                                            <div class="ev-info"><strong>Retro del sprint</strong><div class="ev-resp"><span class="yes">✓16</span><span class="no">✗2</span></div></div>
                                        </div>
                                        <div class="event-row">
                                            <div class="ev-date"><b>03</b><small>ABR</small></div>
                                            <div class="ev-info"><strong>Team lunch onboarding</strong><div class="ev-resp"><span class="yes">✓22</span><span class="no">✗1</span></div></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="feature-text">
                    <h3>Detección de eventos</h3>
                    <p>Grupero detecta automáticamente los eventos del chat: quién confirmó, quién declinó, quién nunca respondió. Historial completo de asistencia.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .features {
        padding: 100px 0;
        background: linear-gradient(180deg, #f8faf8 0%, #fff 100%);
    }

    .features-header {
        text-align: center;
        margin-bottom: 80px;
    }

    .features-badge {
        display: inline-block;
        background: #E8F8ED;
        color: #16a34a;
        font-size: 0.85rem;
        font-weight: 600;
        padding: 6px 16px;
        border-radius: 20px;
        margin-bottom: 16px;
    }

    .section-title {
        font-size: 2.75rem;
        font-weight: 800;
        margin-bottom: 12px;
        color: #1a1a1a;
    }

    .section-subtitle {
        font-size: 1.2rem;
        color: #6b7280;
        max-width: 500px;
        margin: 0 auto;
    }

    .features-list {
        display: flex;
        flex-direction: column;
        gap: 100px;
    }

    .feature-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
    }

    .feature-row.reverse {
        direction: rtl;
    }

    .feature-row.reverse > * {
        direction: ltr;
    }

    .feature-text h3 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 16px;
    }

    .feature-text p {
        font-size: 1.1rem;
        color: #6b7280;
        line-height: 1.7;
    }

    /* Phone */
    .phone {
        width: 280px;
        height: 500px;
        background: #111;
        border-radius: 44px;
        padding: 10px;
        margin: 0 auto;
        box-shadow: 0 40px 80px -20px rgba(0,0,0,0.3);
    }

    .phone-notch {
        width: 90px;
        height: 24px;
        background: #111;
        border-radius: 14px;
        margin: 0 auto 8px;
    }

    .phone-screen {
        background: #f5f5f5;
        border-radius: 36px;
        height: calc(100% - 32px);
        overflow: hidden;
    }

    .screen-header {
        background: #25D366;
        color: white;
        padding: 14px 16px;
        font-size: 14px;
        font-weight: 600;
    }

    .screen-body {
        padding: 12px;
    }

    /* Health Card */
    .health-card {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        border-radius: 14px;
        padding: 14px;
        color: white;
        margin-bottom: 10px;
    }

    .health-top {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
    }

    .health-emoji { font-size: 28px; }

    .health-text {
        flex: 1;
    }

    .health-text small {
        font-size: 10px;
        opacity: 0.9;
        display: block;
    }

    .health-text strong {
        font-size: 16px;
    }

    .health-score {
        width: 40px;
        height: 40px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        font-weight: 700;
    }

    .health-row {
        display: flex;
        gap: 6px;
    }

    .health-stat {
        flex: 1;
        background: rgba(255,255,255,0.15);
        border-radius: 8px;
        padding: 8px 4px;
        text-align: center;
        font-size: 9px;
    }

    .health-stat span { display: block; font-size: 14px; }
    .health-stat b { display: block; font-size: 14px; }

    /* Semaforo Card */
    .sem-card {
        background: white;
        border-radius: 12px;
        padding: 12px;
        border: 1px solid #e5e7eb;
    }

    .sem-title {
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 10px;
        color: #1a1a1a;
    }

    .sem-bars {
        display: flex;
        gap: 6px;
        margin-bottom: 10px;
    }

    .bar {
        flex: 1;
        padding: 10px 6px;
        border-radius: 8px;
        text-align: center;
    }

    .bar.green { background: #dcfce7; }
    .bar.yellow { background: #fef3c7; }
    .bar.red { background: #fee2e2; }

    .bar .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin: 0 auto 4px;
    }

    .bar.green .dot { background: #22c55e; box-shadow: 0 0 6px #22c55e; }
    .bar.yellow .dot { background: #f59e0b; box-shadow: 0 0 6px #f59e0b; }
    .bar.red .dot { background: #ef4444; box-shadow: 0 0 6px #ef4444; }

    .bar span { display: block; font-size: 16px; font-weight: 700; color: #1a1a1a; }
    .bar small { font-size: 9px; color: #6b7280; }

    .sem-progress {
        display: flex;
        height: 6px;
        border-radius: 3px;
        overflow: hidden;
    }

    .fill-green { flex: 80; background: #22c55e; }
    .fill-yellow { flex: 14; background: #f59e0b; }
    .fill-red { flex: 6; background: #ef4444; }

    /* Rank Card */
    .rank-card {
        background: white;
        border-radius: 12px;
        padding: 12px;
        border: 1px solid #e5e7eb;
    }

    .rank-title {
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 12px;
        color: #1a1a1a;
    }

    .rank-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .rank-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .medal, .pos { width: 22px; text-align: center; font-size: 14px; }
    .pos { color: #9ca3af; font-size: 11px; }

    .avatar {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 600;
    }

    .a1 { background: #dcfce7; color: #166534; }
    .a2 { background: #dbeafe; color: #1e40af; }
    .a3 { background: #fef3c7; color: #92400e; }
    .a4 { background: #fce7f3; color: #be185d; }

    .rank-info {
        flex: 1;
    }

    .rank-info strong {
        display: block;
        font-size: 11px;
        color: #1a1a1a;
        margin-bottom: 3px;
    }

    .rank-bar {
        height: 5px;
        background: #e5e7eb;
        border-radius: 3px;
        overflow: hidden;
    }

    .rank-bar .fill {
        height: 100%;
        background: linear-gradient(90deg, #22c55e, #16a34a);
        border-radius: 3px;
    }

    .rank-num {
        text-align: right;
    }

    .rank-num b { display: block; font-size: 12px; color: #1a1a1a; }
    .rank-num small { font-size: 9px; color: #9ca3af; }

    /* Alert Card */
    .alert-card {
        background: white;
        border-radius: 12px;
        padding: 12px;
        border: 1px solid #fde68a;
        border-left: 3px solid #f59e0b;
    }

    .alert-title {
        font-size: 13px;
        font-weight: 600;
        color: #1a1a1a;
    }

    .alert-sub {
        font-size: 11px;
        color: #d97706;
        margin-bottom: 12px;
    }

    .alert-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .alert-row {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #fffbeb;
        padding: 10px;
        border-radius: 8px;
    }

    .alert-badge {
        background: #fef3c7;
        color: #92400e;
        font-size: 10px;
        font-weight: 700;
        padding: 4px 6px;
        border-radius: 4px;
    }

    .alert-info {
        flex: 1;
    }

    .alert-info strong { display: block; font-size: 11px; color: #1a1a1a; }
    .alert-info small { font-size: 9px; color: #6b7280; }

    .alert-decay {
        background: #fee2e2;
        color: #dc2626;
        font-size: 10px;
        font-weight: 700;
        padding: 4px 8px;
        border-radius: 12px;
    }

    /* Heat Card */
    .heat-card {
        background: white;
        border-radius: 12px;
        padding: 12px;
        border: 1px solid #e5e7eb;
    }

    .heat-title {
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 12px;
        color: #1a1a1a;
    }

    .heatmap {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .heat-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .heat-row span {
        width: 24px;
        font-size: 9px;
        color: #9ca3af;
    }

    .cells {
        display: flex;
        gap: 3px;
    }

    .cells i, .heat-legend i {
        width: 14px;
        height: 14px;
        border-radius: 3px;
        display: inline-block;
    }

    .c0 { background: #ebedf0; }
    .c1 { background: #9be9a8; }
    .c2 { background: #40c463; }
    .c3 { background: #30a14e; }
    .c4 { background: #216e39; }

    .heat-legend {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        margin-top: 12px;
        font-size: 9px;
        color: #9ca3af;
    }

    /* Events Card */
    .events-card {
        background: white;
        border-radius: 12px;
        padding: 12px;
        border: 1px solid #e5e7eb;
    }

    .events-title {
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 12px;
        color: #1a1a1a;
    }

    .events-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .event-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        background: #f9fafb;
        border-radius: 10px;
    }

    .event-row.next {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
    }

    .ev-date {
        text-align: center;
    }

    .ev-date b { display: block; font-size: 16px; color: #1a1a1a; }
    .ev-date small { font-size: 9px; color: #6b7280; }

    .ev-info {
        flex: 1;
    }

    .ev-info strong { display: block; font-size: 11px; color: #1a1a1a; margin-bottom: 4px; }

    .ev-resp {
        display: flex;
        gap: 8px;
        font-size: 10px;
    }

    .ev-resp .yes { color: #16a34a; }
    .ev-resp .no { color: #dc2626; }
    .ev-resp .maybe { color: #d97706; }

    .ev-badge {
        background: #22c55e;
        color: white;
        font-size: 9px;
        font-weight: 600;
        padding: 3px 8px;
        border-radius: 10px;
    }

    @media (max-width: 900px) {
        .feature-row,
        .feature-row.reverse {
            grid-template-columns: 1fr;
            gap: 40px;
            direction: ltr;
        }

        .feature-visual {
            order: -1;
        }

        .feature-text {
            text-align: center;
        }

        .section-title {
            font-size: 2rem;
        }

        .phone {
            width: 240px;
            height: 420px;
        }
    }
</style>
