              <div class="date"><span class="d">01</span><span class="m">ABR</span></div>
              <div><div class="e-name">Entreno + asado</div><div class="e-sub">Sáb 17:00</div></div>
              <div class="counts"><span class="c-y">✓22</span><span class="c-n">✗1</span></div>
            </div>
          </div>
        </div>
        <div class="gif-progress"></div>
      </div>
    </div>

    <!-- Panel: AI -->
    <div class="feat-panel reverse hidden" data-panel="ai">
      <div class="feat-text">
        <span class="feat-badge">● Plan Pro</span>
        <h3>Pregúntale <em>cualquier cosa</em> a tu grupo.</h3>
        <p>"¿Quién organiza más eventos?" "Resume esta semana." "¿Quién falta más seguido?" La IA lee tu chat y responde en lenguaje natural.</p>
        <ul class="feat-bullets">
          <li>100% on-device — ninguna pregunta sale de tu teléfono</li>
          <li>Contexto completo: usa todo tu historial analizado</li>
          <li>Atajos precargados: "resumen de la semana", "próximos eventos"</li>
        </ul>
      </div>
      <div class="feat-gif-wrap">
        <div class="hero-gif-label"><span>IA · chat</span><span class="dots"><span class="dot on"></span><span class="dot"></span></span></div>
        <div class="gif gif-ai">
          <div class="chat">
            <div class="msg u">¿Quién es el más activo esta semana?</div>
            <div class="typing"><span></span><span></span><span></span></div>
            <div class="msg b"><b>María García</b> lidera con <em>184 mensajes</em> y confirmó los 3 eventos. Le sigue Carlos López (121).</div>
            <div class="msg u2">Resume lo importante</div>
            <div class="msg b2">3 acuerdos: <em>asado el domingo 17:00, cuota de $500, entreno movido a martes</em>. Pendiente: respuesta de Pedro sobre el uniforme.</div>
          </div>
        </div>
        <div class="gif-progress"></div>
      </div>
    </div>

  </div>
</section>

<script>
  // Feature tabs
  const tabs = document.querySelectorAll('.feat-tab');
  const panels = document.querySelectorAll('.feat-panel');
  tabs.forEach(t => {
    t.addEventListener('click', () => {
      tabs.forEach(x => x.classList.remove('active'));
      t.classList.add('active');
      const id = t.dataset.tab;
      panels.forEach(p => p.classList.toggle('hidden', p.dataset.panel !== id));
    });
  });

  // Heatmap generator — deterministic fake data with Sunday 6pm spike
  (() => {
    const grid = document.getElementById('heatgrid');
    if (!grid) return;
    const days = ['L','M','X','J','V','S','D'];
    let html = '<div class="dayL"></div>';
    for (let h = 0; h < 24; h += 3) html += `<div class="dayL" style="grid-column:span 3;text-align:center">${h}</div>`;
    days.forEach((d, di) => {
      html += `<div class="dayL">${d}</div>`;
      for (let h = 0; h < 24; h++) {
        let level = 0;
        if (h >= 7 && h <= 22) {
          const isWeekend = di >= 5;
          const evening = h >= 18 && h <= 21;
          const noon = h >= 12 && h <= 14;
          let base = 1;
          if (evening) base = 3;
          else if (noon) base = 2;
          if (isWeekend && evening) base = 4;
          if (di === 6 && h === 18) base = 4; // Sunday 6pm fuego
          level = base - (Math.abs((di + h) % 5 === 0 ? 1 : 0));
          level = Math.max(0, Math.min(4, level));
        }
        const delay = (di * 24 + h) * 0.015;
        html += `<div class="cell l${level}" style="animation-delay:${delay}s"></div>`;
      }
    });
    grid.innerHTML = html;
  })();
</script>
