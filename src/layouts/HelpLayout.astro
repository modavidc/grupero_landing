---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
    title: string;
    description?: string;
}

const { title, description } = Astro.props;
---

<Layout title={title + " — Grupero"} description={description}>
    <Header />
    <main class="help-page">
        <slot />
    </main>
    <Footer />
</Layout>

<style>
    .help-page {
        padding-top: 72px;
        min-height: 70vh;
    }
</style>

<style is:global>

/* =========================================
   Help — Hero strip (consistent with landing sections)
   ========================================= */
.help-hero {
    background: linear-gradient(135deg, #064E3B 0%, var(--brand) 50%, var(--brand-2) 100%);
    color: #fff;
    padding: 80px 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
}
.help-hero::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(circle at 20% 50%, rgba(37,211,102,.18) 0%, transparent 50%),
                radial-gradient(circle at 80% 30%, rgba(37,211,102,.12) 0%, transparent 40%);
    pointer-events: none;
}
.help-hero-content {
    position: relative; z-index: 1;
    max-width: 700px; margin: 0 auto;
    animation: fadeUp .65s var(--ease) .1s both;
}
.help-hero h1 {
    font-size: clamp(32px, 4vw, 56px);
    font-weight: 800; letter-spacing: -.03em;
    color: #fff; margin-bottom: 12px;
}
.help-hero p {
    font-size: clamp(16px, 1.4vw, 19px);
    color: rgba(255,255,255,.82); margin-bottom: 32px;
}

/* Search */
.search-container {
    max-width: 600px; margin: 0 auto; position: relative;
}
.search-box {
    width: 100%; padding: 18px 24px 18px 56px;
    font-size: 16px; border: none; border-radius: 14px;
    background: #fff;
    box-shadow: 0 16px 40px -12px rgba(0,0,0,.25);
    outline: none; font-family: var(--f-body);
    transition: box-shadow .25s var(--ease);
    color: var(--ink);
}
.search-box::placeholder { color: var(--muted); }
.search-box:focus { box-shadow: 0 20px 48px -12px rgba(0,0,0,.32); }
.search-icon {
    position: absolute; left: 20px; top: 50%;
    transform: translateY(-50%);
    width: 22px; height: 22px; color: var(--muted);
}
.quick-links {
    display: flex; justify-content: center;
    gap: 10px; margin-top: 24px; flex-wrap: wrap;
}
.quick-link {
    background: rgba(255,255,255,.15);
    backdrop-filter: blur(8px);
    padding: 8px 18px; border-radius: 999px;
    font-size: 13px; font-weight: 600; color: #fff;
    transition: background .2s var(--ease), transform .2s var(--ease);
}
.quick-link:hover {
    background: rgba(255,255,255,.28);
    transform: translateY(-2px);
}

/* =========================================
   Help — Category cards
   ========================================= */
.help-categories {
    padding: 72px 24px;
    max-width: 1200px; margin: 0 auto;
}
.help-section-title {
    font-size: clamp(24px, 2.5vw, 36px);
    font-weight: 800; letter-spacing: -.025em;
    color: var(--ink); margin-bottom: 32px;
}
.categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
}
.category-card {
    background: var(--paper); border-radius: 20px;
    padding: 28px; border: 1px solid var(--line);
    transition: transform .3s var(--ease), box-shadow .3s, border-color .2s;
    text-decoration: none; color: inherit; display: block;
    box-shadow: 0 2px 8px rgba(0,0,0,.04);
}
.category-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px -24px rgba(18,140,62,.2);
    border-color: #bbf7d0;
}
.category-icon {
    width: 52px; height: 52px; border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem; margin-bottom: 16px;
}
.category-card h3 {
    font-size: 18px; font-weight: 700; letter-spacing: -.015em;
    margin-bottom: 8px; color: var(--ink);
}
.category-card p {
    font-size: 14px; color: var(--ink-3);
    line-height: 1.65; margin-bottom: 12px;
}
.category-articles { font-size: 13px; color: var(--brand); font-weight: 600; }

/* Category icon backgrounds */
.cat-getting-started .category-icon { background: var(--bg-2); }
.cat-import .category-icon { background: #EFF6FF; }
.cat-analysis .category-icon { background: #FFFBEB; }
.cat-events .category-icon { background: #FDF2F8; }
.cat-sports .category-icon { background: #F5F3FF; }
.cat-export .category-icon { background: #F0FDFA; }
.cat-privacy .category-icon { background: #EEF2FF; }
.cat-account .category-icon { background: #FEFCE8; }
.cat-errors .category-icon { background: #FFF1F2; }

/* =========================================
   Popular articles strip
   ========================================= */
.popular-articles {
    background: var(--bg-2); padding: 60px 24px;
}
.popular-articles .container {
    max-width: 1200px; margin: 0 auto;
}
.articles-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 14px;
}
.article-item {
    background: var(--paper); padding: 18px 22px;
    border-radius: 14px; border: 1px solid var(--line);
    display: flex; align-items: center; gap: 14px;
    text-decoration: none; color: inherit;
    transition: border-color .2s var(--ease), background .2s, transform .2s var(--ease);
}
.article-item:hover {
    border-color: #bbf7d0; background: var(--bg-2);
    transform: translateY(-2px);
}
.article-icon {
    width: 40px; height: 40px; background: var(--chip);
    border-radius: 10px; display: flex;
    align-items: center; justify-content: center; flex-shrink: 0;
}
.article-content h4 {
    font-size: 15px; font-weight: 600;
    color: var(--ink); margin-bottom: 4px;
}
.article-content p { font-size: 13px; color: var(--ink-3); margin: 0; }

/* =========================================
   Article page
   ========================================= */
.help-article {
    max-width: 800px; margin: 0 auto;
    padding: 60px 24px 80px;
    animation: fadeUp .55s var(--ease) .05s both;
}

/* Breadcrumb */
.breadcrumb {
    display: flex; align-items: center;
    gap: 8px; margin-bottom: 32px; font-size: 13px;
    color: var(--ink-3);
}
.breadcrumb a {
    color: var(--brand); font-weight: 500;
    transition: text-decoration .15s;
}
.breadcrumb a:hover { text-decoration: underline; }
.breadcrumb span { color: var(--muted); }

/* Article heading */
.help-article h1 {
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 800; letter-spacing: -.03em;
    color: var(--ink); margin-bottom: 12px;
    line-height: 1.08;
}
.article-meta {
    font-size: 13px; color: var(--ink-3);
    margin-bottom: 40px; padding-bottom: 24px;
    border-bottom: 1px solid var(--line); font-weight: 500;
}

/* Article body typography */
.help-content h2 {
    font-size: clamp(20px, 2vw, 26px);
    font-weight: 700; letter-spacing: -.02em;
    color: var(--ink); margin-top: 48px; margin-bottom: 14px;
}
.help-content h3 {
    font-size: 17px; font-weight: 600;
    letter-spacing: -.01em; color: var(--ink-2);
    margin-top: 28px; margin-bottom: 10px;
}
.help-content p {
    color: var(--ink-2); line-height: 1.7;
    margin-bottom: 16px; font-size: 16px;
}
.help-content ul,
.help-content ol {
    margin: 0 0 16px; padding-left: 22px;
}
.help-content li {
    color: var(--ink-2); line-height: 1.7;
    margin-bottom: 7px; font-size: 16px;
}
.help-content ul li { list-style: disc; }
.help-content ol li { list-style: decimal; }
.help-content strong { color: var(--ink); font-weight: 700; }
.help-content a {
    color: var(--brand); text-decoration: underline;
    text-underline-offset: 3px;
    transition: color .15s;
}
.help-content a:hover { color: var(--brand-2); }
.help-content code {
    background: var(--bg-2); padding: 2px 8px;
    border-radius: 6px; font-size: .9em;
    font-family: var(--f-mono); color: var(--brand);
    border: 1px solid #bbf7d0;
}

/* Info / warning boxes */
.info-box {
    background: var(--bg-2);
    border-left: 4px solid var(--accent);
    padding: 16px 20px; border-radius: 0 12px 12px 0;
    margin: 24px 0;
}
.info-box.warning {
    background: #FFFBEB; border-left-color: var(--warn);
}
.info-box.error {
    background: #FFF1F2; border-left-color: var(--danger);
}
.info-box p { margin: 0; color: var(--ink); font-size: 15px; }

/* Step list */
.steps { counter-reset: step; margin: 24px 0; }
.step { display: flex; gap: 16px; margin-bottom: 24px; align-items: flex-start; }
.step-number {
    counter-increment: step;
    width: 32px; height: 32px;
    background: var(--brand); color: var(--accent);
    border-radius: 50%; display: flex;
    align-items: center; justify-content: center;
    font-weight: 800; font-size: 14px; flex-shrink: 0;
    box-shadow: 0 4px 12px rgba(18,140,62,.25);
}
.step-number::before { content: counter(step); }
.step-content h4 { font-weight: 700; margin-bottom: 4px; color: var(--ink); }
.step-content p { color: var(--ink-3); margin: 0; font-size: 15px; }

/* Related articles */
.related-articles {
    margin-top: 60px; padding-top: 40px;
    border-top: 1px solid var(--line);
}
.related-articles h3 {
    font-size: 18px; font-weight: 700;
    letter-spacing: -.015em; margin-bottom: 16px;
    color: var(--ink);
}
.related-list { display: grid; gap: 10px; }
.related-item {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 18px; background: var(--bg-2);
    border-radius: 12px; border: 1px solid var(--line);
    text-decoration: none; color: var(--ink-2); font-size: 15px;
    transition: border-color .2s, background .2s, transform .2s var(--ease);
    font-weight: 500;
}
.related-item:hover {
    border-color: #bbf7d0; background: #e7fdf0;
    transform: translateX(4px);
}

/* Help CTA strip */
.help-cta {
    background: linear-gradient(135deg, var(--brand) 0%, #0d6b30 100%);
    color: #fff; padding: 64px 24px;
    text-align: center; position: relative; overflow: hidden;
}
.help-cta::before {
    content: '';
    position: absolute; inset: 0; pointer-events: none; opacity: .15;
    background: radial-gradient(circle at 30% 40%, var(--accent) 0%, transparent 40%),
                radial-gradient(circle at 75% 70%, var(--accent) 0%, transparent 40%);
}
.help-cta h2 { font-size: clamp(24px, 3vw, 36px); color: #fff; margin-bottom: 12px; }
.help-cta p { color: rgba(255,255,255,.78); margin-bottom: 28px; font-size: 17px; }
.help-cta .btn {
    background: #fff; color: var(--brand);
    padding: 14px 28px; border-radius: 999px;
    font-weight: 700; display: inline-block;
    transition: transform .2s var(--ease), box-shadow .2s;
}
.help-cta .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px -8px rgba(0,0,0,.25);
}

/* Search results */
.search-results {
    display: none; position: absolute; top: 100%;
    left: 0; right: 0; background: var(--paper);
    border-radius: 14px;
    box-shadow: 0 16px 40px -12px rgba(0,0,0,.2);
    margin-top: 8px; max-height: 380px;
    overflow-y: auto; z-index: 100;
    border: 1px solid var(--line);
}
.search-results.active { display: block; }
.search-result-item {
    padding: 14px 22px;
    border-bottom: 1px solid var(--line);
    text-decoration: none; color: inherit; display: block;
    transition: background .15s;
}
.search-result-item:hover { background: var(--bg-2); }
.search-result-item:last-child { border-bottom: none; }
.search-result-item h4 { font-weight: 600; color: var(--ink); margin-bottom: 3px; font-size: 15px; }
.search-result-item p { font-size: 13px; color: var(--ink-3); margin: 0; }
.search-result-item .category-tag {
    font-size: 11px; background: var(--chip);
    color: var(--brand); padding: 2px 8px;
    border-radius: 999px; margin-left: 8px; font-weight: 600;
}
.no-results { padding: 32px 24px; text-align: center; color: var(--ink-3); }

/* =========================================
   Responsive
   ========================================= */
@media (max-width: 768px) {
    .help-hero { padding: 60px 20px; }
    .help-article { padding: 40px 20px 60px; }
    .help-categories { padding: 48px 20px; }
    .search-box { padding: 14px 20px 14px 48px; font-size: 15px; }
    .categories-grid { grid-template-columns: 1fr; }
    .articles-list { grid-template-columns: 1fr; }
}

</style>
