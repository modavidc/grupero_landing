---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

if (import.meta.env.PROD) {
  return Astro.redirect('/', 301);
}
---

<Layout
  title="Funciones de Grupero — Comparativa completa por plan"
  description="Tabla completa de todas las funciones de Grupero: qué incluye el plan Gratis, Pro y Teams. Cada feature explicado, sin letra pequeña."
>
  <Header />

  <main class="ft-main">

    <!-- Page header -->
    <div class="ft-hero">
      <div class="wrap-sm">
        <span class="kicker kicker-dot">Funciones completas</span>
        <h1 class="ft-title">Todo lo que puede hacer Grupero.</h1>
        <p class="lead">Sin letra pequeña. Cada función explicada, con el plan en que está disponible.</p>
      </div>
    </div>

    <!-- Sticky plan header -->
    <div class="ft-sticky" id="ft-sticky">
      <div class="ft-sticky-inner wrap">
        <div class="ft-sticky-label">Funciones</div>
        <div class="ft-col ft-col-free">
          <span class="ft-plan-name">Gratis</span>
          <span class="ft-plan-price">US$0</span>
          <a href="#descargar" class="btn btn-ghost ft-cta">Descargar</a>
        </div>
        <div class="ft-col ft-col-pro ft-col-featured">
          <span class="ft-plan-badge">Recomendado</span>
          <span class="ft-plan-name">Pro</span>
          <span class="ft-plan-price">US$6.67<sup>/mes</sup></span>
          <a href="#descargar" class="btn btn-accent ft-cta">Probar gratis →</a>
        </div>
        <div class="ft-col ft-col-teams">
          <span class="ft-plan-name">Teams</span>
          <span class="ft-plan-price">US$15<sup>/mes</sup></span>
          <a href="/contacto" class="btn btn-ghost ft-cta">Contactar</a>
        </div>
      </div>
    </div>

    <!-- Feature table -->
    <div class="ft-table-wrap wrap">
      <div class="ft-table" role="table">

        <!-- ── IMPORTACIÓN Y ANÁLISIS ── -->
        <div class="ft-category" role="rowgroup">
          <div class="ft-cat-header" role="row">
            <span>📥 Importación y análisis</span>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Importar chat desde WhatsApp (ZIP)</span>
              <span class="ft-feat-desc">Arrastra el archivo exportado y en 30 segundos tienes el análisis completo.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check" aria-label="Incluido">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check" aria-label="Incluido">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check" aria-label="Incluido">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Múltiples grupos simultáneos</span>
              <span class="ft-feat-desc">Analiza todos los grupos que quieras, sin límite de cantidad.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Análisis 100% offline</span>
              <span class="ft-feat-desc">Todo se procesa en tu teléfono. No necesitas internet, no hay servidores.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Re-análisis con historial de snapshots</span>
              <span class="ft-feat-desc">Re-importa el mismo grupo y compara cómo evolucionó respecto al análisis anterior.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Búsqueda full-text en mensajes</span>
              <span class="ft-feat-desc">Busca cualquier palabra o frase en el historial del chat. Filtra por remitente.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Exportar análisis a CSV y PDF</span>
              <span class="ft-feat-desc">Descarga el análisis completo o solo el ranking para usarlo fuera de la app.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Compartir análisis directamente</span>
              <span class="ft-feat-desc">Envía el reporte completo por WhatsApp, email o cualquier app de tu teléfono.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>
        </div>

        <!-- ── SALUD DEL GRUPO ── -->
        <div class="ft-category" role="rowgroup">
          <div class="ft-cat-header" role="row">
            <span>🩺 Salud del grupo</span>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Semáforo verde / amarillo / rojo</span>
              <span class="ft-feat-desc">Clasifica a cada miembro según su participación reciente: activo, en riesgo o inactivo.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Score de salud 0–100</span>
              <span class="ft-feat-desc">Un número que resume qué tan vivo está el grupo. Actualizable al re-importar.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row ft-row-pro" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Panel de salud avanzado</span>
              <span class="ft-feat-desc">Vista detallada con factores de salud, tendencias y diagnóstico de dinámicas del grupo.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-dash" aria-label="No incluido">—</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row ft-row-pro" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Histórico de salud mes a mes</span>
              <span class="ft-feat-desc">Visualiza cómo evolucionó la salud del grupo en el tiempo con cada re-importación.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-dash">—</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>
        </div>

        <!-- ── PARTICIPACIÓN ── -->
        <div class="ft-category" role="rowgroup">
          <div class="ft-cat-header" role="row">
            <span>🏆 Participación y ranking</span>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Ranking de participación</span>
              <span class="ft-feat-desc">Top de miembros con score compuesto: mensajes + asistencia + respuestas a eventos. Con medallas y porcentajes.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Estadísticas de mensajes</span>
              <span class="ft-feat-desc">Total de mensajes, palabras, emojis, media y links por miembro y por grupo.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Menciones frecuentes</span>
              <span class="ft-feat-desc">Matriz de quién menciona a quién en el chat. Detecta relaciones y sub-grupos dentro del grupo.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Nube de emojis del grupo</span>
              <span class="ft-feat-desc">Los emojis más usados del grupo, con frecuencia. El termómetro emocional visual del chat.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Palabras más frecuentes</span>
              <span class="ft-feat-desc">El vocabulario real del grupo. Útil para detectar temas recurrentes y dinámicas internas.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Initiadores de conversación</span>
              <span class="ft-feat-desc">Quién rompe el silencio más frecuentemente. Identifica a los motores sociales del grupo.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row ft-row-pro" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Lista de inactivos con evidencia</span>
              <span class="ft-feat-desc">Los miembros que no participan, con última fecha de actividad y sugerencia de acción.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-dash">—</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row ft-row-pro" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Alertas de silencio crítico</span>
              <span class="ft-feat-desc">Cuando alguien importante deja de participar, te avisamos. Umbral configurable: 7, 14 o 30 días.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-dash">—</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row ft-row-pro" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Tiempos de respuesta</span>
              <span class="ft-feat-desc">Cuánto tarda cada miembro en responder mensajes. Detecta quién lee y no contesta.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-dash">—</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row ft-row-pro" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Análisis de sentimiento</span>
              <span class="ft-feat-desc">Tono general del grupo (positivo / neutro / negativo) y evolución en el tiempo.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-dash">—</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Clasificación de actividad por miembro</span>
              <span class="ft-feat-desc">Cada miembro categorizado automáticamente: Activo, Esporádico, Observador silencioso o Inactivo.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Links compartidos por categoría</span>
              <span class="ft-feat-desc">Desglose de links en el grupo: YouTube, Spotify, Instagram, TikTok, noticias, etc. Con barras de progreso.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Mensajes eliminados</span>
              <span class="ft-feat-desc">Conteo de mensajes borrados por usuario. Un indicador sutil de dinamicas internas del grupo.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>
        </div>

        <!-- ── ACTIVIDAD TEMPORAL ── -->
        <div class="ft-category" role="rowgroup">
          <div class="ft-cat-header" role="row">
            <span>📊 Actividad y tiempo</span>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Heatmap de actividad 7×24</span>
              <span class="ft-feat-desc">Mapa visual de actividad hora × día. Sabe exactamente cuándo está más vivo tu grupo.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Gráfico de actividad por día de semana</span>
              <span class="ft-feat-desc">Distribución de mensajes por día (Lun–Dom). Detecta los días más y menos activos.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Línea de tiempo de mensajes</span>
              <span class="ft-feat-desc">Evolución diaria del volumen de mensajes desde el inicio del chat hasta hoy.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Día más activo y hora pico</span>
              <span class="ft-feat-desc">El día con más mensajes en toda la historia del grupo y la franja horaria de mayor actividad.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Racha más larga</span>
              <span class="ft-feat-desc">Los días consecutivos con actividad en el grupo. Mide la constancia y el engagement sostenido.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>
        </div>

        <!-- ── EVENTOS ── -->
        <div class="ft-category" role="rowgroup">
          <div class="ft-cat-header" role="row">
            <span>📅 Eventos y convocatorias</span>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Detección automática de eventos</span>
              <span class="ft-feat-desc">Grupero lee el chat y detecta fechas, convocatorias y actividades sin que tengas que marcarlas.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Historial de asistencia por evento</span>
              <span class="ft-feat-desc">Quién confirmó, quién declinó y quién nunca respondió en cada evento detectado.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">Patrón "confirma pero no va"</span>
              <span class="ft-feat-desc">Detecta a quienes confirman asistencia sistemáticamente pero luego no aparecen.</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

          <div class="ft-row ft-row-pro" role="row">
            <div class="ft-feat" role="cell">
              <span class="ft-feat-name">FAQ auto-generadas</span>
              <span class="ft-feat-desc">Preguntas frecuentes del grupo detectadas automáticamente. ¿Cuándo es el próximo partido? ¿Cuánto es la cuota?</span>
            </div>
            <div class="ft-val ft-val-free" role="cell"><span class="ft-dash">—</span></div>
            <div class="ft-val ft-val-pro" role="cell"><span class="ft-check">✓</span></div>
            <div class="ft-val ft-val-teams" role="cell"><span class="ft-check">✓</span></div>
          </div>

